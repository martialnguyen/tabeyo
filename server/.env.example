PORT=5000
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@app.local
ADMIN_PASSWORD=123456
ADMIN_TOKEN=dev-admin-token-change-me
CRON_SECRET=dev-cron-secret-change-me
ENABLE_AUTO_SOLD=true

# Firebase Admin credentials. Use option A or option B.
# Option A: path to the service account JSON file downloaded from Firebase Console.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Option B: paste individual fields from the service account JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional Discord new-order notifications
DISCORD_WEBHOOK_URL=
